<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Formular_Novy.ViewModels"
             x:DataType="vm:GameListViewModel"
             x:Class="Formular_Novy.Views.GameListView"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16">

        <!-- ═══ Header ════════════════════════════════════════ -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0">
                <TextBlock Text="🎮 Game Tracker"
                           FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Správa herní knihovny"
                           FontSize="13" Opacity="0.6" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="+ Přidat hru"
                    Command="{Binding AddGameCommand}"
                    VerticalAlignment="Center"
                    Padding="14,8" />
        </Grid>

        <!-- ═══ Filtrování / vyhledávání ═════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,10">
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="🔍 Hledat podle názvu nebo vývojáře..."
                     Margin="0,0,8,0" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding FilterPlatforms}"
                      SelectedItem="{Binding SelectedFilterPlatform, Mode=TwoWay}"
                      PlaceholderText="Všechny platformy"
                      Width="200"
                      Margin="0,0,8,0" />
            <Button Grid.Column="2"
                    Content="✕ Vymazat"
                    Command="{Binding ClearFilterCommand}"
                    Padding="10,6" />
        </Grid>

        <!-- ═══ Tabulka her ═══════════════════════════════════ -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredGames}"
                  SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Název hry"
                                    Binding="{Binding Title}"
                                    Width="220" />
                <DataGridTextColumn Header="Vývojář"
                                    Binding="{Binding Developer}"
                                    Width="160" />
                <DataGridTextColumn Header="Rok vydání"
                                    Binding="{Binding ReleaseYear}"
                                    Width="90" />
                <DataGridTextColumn Header="Platforma"
                                    Binding="{Binding Platform.Name}"
                                    Width="160" />
                <DataGridTextColumn Header="Poznámky"
                                    Binding="{Binding Notes}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══ Statistiky / dashboard ═══════════════════════ -->
        <Border Grid.Row="3"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="8"
                Padding="14,10"
                Margin="0,10,0,0">
            <StackPanel Spacing="6">

                <!-- Souhrnné čísla -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <TextBlock FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🎮 Her celkem: {0}">
                                <Binding Path="TotalGames" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="⏱ Odehráno celkem: {0:F1} h">
                                <Binding Path="TotalHours" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Rozpad podle platforem -->
                <ItemsControl ItemsSource="{Binding PlatformStats}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10,3"
                                    Margin="0,0,6,2">
                                <TextBlock Text="{Binding .}" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>

        <!-- ═══ Akční tlačítka (aktivní jen při výběru) ═════ -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,10,0,0">

            <Button Content="📋 Detail"
                    Command="{Binding GoToDetailCommand}"
                    Padding="12,6" />
            <Button Content="✏️ Upravit"
                    Command="{Binding EditSelectedGameCommand}"
                    Padding="12,6" />
            <Button Content="🗑️ Smazat"
                    Command="{Binding DeleteSelectedGameCommand}"
                    Padding="12,6" />

            <TextBlock Text="← Vyberte hru v tabulce"
                       VerticalAlignment="Center"
                       Opacity="0.5"
                       FontStyle="Italic"
                       Margin="8,0,0,0">
                <TextBlock.IsVisible>
                    <Binding Path="SelectedGame"
                             Converter="{x:Static ObjectConverters.IsNull}" />
                </TextBlock.IsVisible>
            </TextBlock>

        </StackPanel>
    </Grid>
</UserControl>
